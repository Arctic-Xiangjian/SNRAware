from torch.optim.lr_scheduler import CosineAnnealingLR


def _forward_model(model, img_lq, mask_we_use, lq_kspace, use_bf16):
    if "use_bf16" in inspect.signature(model.forward).parameters:
        return model(img_lq, mask_we_use, lq_kspace, use_bf16=use_bf16)
    return model(img_lq, mask_we_use, lq_kspace)


def train(
    model,
    train_loader,
    val_loader,
    test_loader,
    optimizer,
    criterion,
    device,
    epochs,
    lr,
    model_name,
    loss_name,
    save_dir,
    args,
    run_name,
    ema_model=None,
):
    # current_time 
    wandb.init(
        project='fastMRI_with_ODE',
        name=run_name,
        config=vars(args),
    )
    best_psnr = float('-inf')
    best_ssim = float('-inf')
    best_nmse = float('inf')
    best_psnr_ema = float('-inf')
    model.train()
    model = model.to(device)
    best_psnr_model = copy.deepcopy(model)
    best_ssim_model = copy.deepcopy(model)
    best_nmse_model = copy.deepcopy(model)
    best_psnr_ema_model = copy.deepcopy(ema_model.module) if ema_model is not None else None
    epoch_psnr = -1
    epoch_ssim = -1
    epoch_nmse = -1
    epoch_psnr_ema = -1
    global_step = 0
    os.makedirs(save_dir, exist_ok=True)

    lr_scheduler_G = CosineAnnealingLR(optimizer, T_max=epochs, eta_min=1e-6)
    wandb.define_metric("custom_step")
    # define which metrics will be plotted against it
    wandb.define_metric("Val/PSNR", step_metric="custom_step")
    wandb.define_metric("Val/SSIM", step_metric="custom_step")
    wandb.define_metric("Val/nmse", step_metric="custom_step")
    if ema_model is not None:
        wandb.define_metric("Val/PSNR_EMA", step_metric="custom_step")
        wandb.define_metric("Val/SSIM_EMA", step_metric="custom_step")
        wandb.define_metric("Val/nmse_EMA", step_metric="custom_step")
    for epoch in range(epochs):
        loss_sum = 0
        for i, (imgLQ, imgHQ, sampler) in tqdm(enumerate(train_loader), total=len(train_loader)):
            # break # for debug
            # imgLQ, imgHQ is double tensor need to convert to float tensor
            # break # for debug
            imgHQ = imgHQ.type(torch.FloatTensor)
            imgLQ = imgLQ.type(torch.FloatTensor)
            mask_we_use = sampler['mask'].to(device)
            lq_kspace = sampler['masked_kspace'].to(device)
            imgLQ, imgHQ = imgLQ.to(device), imgHQ.to(device)
            optimizer.zero_grad()
            output = _forward_model(model, imgLQ, mask_we_use, lq_kspace, args.use_bf16)
            loss = criterion(output, imgHQ)
            loss.backward()
            optimizer.step()
            if ema_model is not None:
                ema_model.update(model)
            loss_sum += loss.item()
            


            if (i+1) % 100 == 0:
                wandb.log({'Train/Loss': loss_sum/100}, step=global_step)
                loss_sum = 0


            global_step += 1

        psnr, ssim, nmse, *_ = test(model, val_loader, device, use_bf16=False) # keep validation evaluation in fp32 to avoid low-precision pollution
        wandb.log({
            'Val/PSNR': psnr,
            'Val/SSIM': ssim,
            'Val/nmse': nmse,
            'custom_step': epoch
        })
        print(f'Epoch [{epoch+1}/{epochs}], PSNR: {psnr:.4f}, SSIM: {ssim:.4f}, nmse: {nmse:.4f}')
        if psnr > best_psnr:
            best_psnr_model = copy.deepcopy(model)
            best_psnr = psnr
            epoch_psnr = epoch
            torch.save(best_psnr_model.state_dict(), os.path.join(save_dir, 'best_psnr_model.pth'))
        if ssim > best_ssim:
            best_ssim_model = copy.deepcopy(model)
            best_ssim = ssim
            epoch_ssim = epoch
            torch.save(best_ssim_model.state_dict(), os.path.join(save_dir, 'best_ssim_model.pth'))
        if nmse < best_nmse:
            best_nmse_model = copy.deepcopy(model)
            best_nmse = nmse
            epoch_nmse = epoch
            torch.save(best_nmse_model.state_dict(), os.path.join(save_dir, 'best_nmse_model.pth'))
        if ema_model is not None:
            psnr_ema, ssim_ema, nmse_ema, *_ = test(
                ema_model.module,
                val_loader,
                device,
                use_bf16=False, # keep EMA evaluation in fp32 to avoid low-precision pollution
            )
            wandb.log({
                'Val/PSNR_EMA': psnr_ema,
                'Val/SSIM_EMA': ssim_ema,
                'Val/nmse_EMA': nmse_ema,
                'custom_step': epoch
            })
            if psnr_ema > best_psnr_ema:
                best_psnr_ema_model = copy.deepcopy(ema_model.module)
                best_psnr_ema = psnr_ema
                epoch_psnr_ema = epoch
                torch.save(
                    best_psnr_ema_model.state_dict(),
                    os.path.join(save_dir, 'best_psnr_ema_model.pth'),
                )
        torch.save(model.state_dict(), os.path.join(save_dir, 'last.pth'))

        lr_scheduler_G.step()
        # print current learning rate
        print(f'Learning rate: {optimizer.param_groups[0]["lr"]}')
    best_psnr_model_psnr, best_psnr_model_ssim, best_psnr_model_nmse, best_psnr_model_psnr_std, best_psnr_model_ssim_std, best_psnr_model_nmse_std = test(best_psnr_model, test_loader, device, use_bf16=args.use_bf16)
    if epoch_psnr != epoch_ssim:
        best_ssim_model_psnr, best_ssim_model_ssim, best_ssim_model_nmse, best_ssim_model_psnr_std, best_ssim_model_ssim_std, best_ssim_model_nmse_std = test(best_ssim_model, test_loader, device, use_bf16=args.use_bf16)
    else:
        best_ssim_model_psnr, best_ssim_model_ssim, best_ssim_model_nmse, best_ssim_model_psnr_std, best_ssim_model_ssim_std, best_ssim_model_nmse_std = best_psnr_model_psnr, best_psnr_model_ssim, best_psnr_model_nmse, best_psnr_model_psnr_std, best_psnr_model_ssim_std, best_psnr_model_nmse_std
    if epoch_nmse != epoch_ssim and epoch_nmse != epoch_psnr:
        best_nmse_model_psnr, best_nmse_model_ssim, best_nmse_model_nmse, best_nmse_model_psnr_std, best_nmse_model_ssim_std, best_nmse_model_nmse_std = test(best_nmse_model, test_loader, device, use_bf16=args.use_bf16)
    else:
        best_nmse_model_psnr, best_nmse_model_ssim, best_nmse_model_nmse, best_nmse_model_psnr_std, best_nmse_model_ssim_std, best_nmse_model_nmse_std = best_psnr_model_psnr, best_psnr_model_ssim, best_psnr_model_nmse, best_psnr_model_psnr_std, best_psnr_model_ssim_std, best_psnr_model_nmse_std
    if best_psnr_ema_model is not None:
        best_psnr_ema_model_psnr, best_psnr_ema_model_ssim, best_psnr_ema_model_nmse, best_psnr_ema_model_psnr_std, best_psnr_ema_model_ssim_std, best_psnr_ema_model_nmse_std = test(
            best_psnr_ema_model,
            test_loader,
            device,
            use_bf16=args.use_bf16,
        )
        wandb.log({
            'best_psnr_ema_model_psnr': best_psnr_ema_model_psnr,
            'best_psnr_ema_model_ssim': best_psnr_ema_model_ssim,
            'best_psnr_ema_model_nmse': best_psnr_ema_model_nmse,
            'best_psnr_ema_model_psnr_std': best_psnr_ema_model_psnr_std,
            'best_psnr_ema_model_ssim_std': best_psnr_ema_model_ssim_std,
            'best_psnr_ema_model_nmse_std': best_psnr_ema_model_nmse_std,
        })
    wandb.log({'best_psnr_model_psnr': best_psnr_model_psnr, 'best_psnr_model_ssim': best_psnr_model_ssim, 'best_psnr_model_nmse': best_psnr_model_nmse, 'best_psnr_model_psnr_std': best_psnr_model_psnr_std, 'best_psnr_model_ssim_std': best_psnr_model_ssim_std, 'best_psnr_model_nmse_std': best_psnr_model_nmse_std, 'best_ssim_model_psnr': best_ssim_model_psnr, 'best_ssim_model_ssim': best_ssim_model_ssim, 'best_ssim_model_nmse': best_ssim_model_nmse, 'best_ssim_model_psnr_std': best_ssim_model_psnr_std, 'best_ssim_model_ssim_std': best_ssim_model_ssim_std, 'best_ssim_model_nmse_std': best_ssim_model_nmse_std, 'best_nmse_model_psnr': best_nmse_model_psnr, 'best_nmse_model_ssim': best_nmse_model_ssim, 'best_nmse_model_nmse': best_nmse_model_nmse, 'best_nmse_model_psnr_std': best_nmse_model_psnr_std, 'best_nmse_model_ssim_std': best_nmse_model_ssim_std, 'best_nmse_model_nmse_std': best_nmse_model_nmse_std})
    wandb.log({'best_psnr_model_epoch': epoch_psnr, 'best_ssim_model_epoch': epoch_ssim, 'best_nmse_model_epoch': epoch_nmse})
    if best_psnr_ema_model is not None:
        wandb.log({'best_psnr_ema_model_epoch': epoch_psnr_ema})
    wandb.finish()
    print(f'Best PSNR model achieved at epoch {epoch_psnr}, PSNR: {best_psnr_model_psnr:.4f}, SSIM: {best_psnr_model_ssim:.4f}, nmse: {best_psnr_model_nmse:.4f}')
    print(f'Best SSIM model achieved at epoch {epoch_ssim}, PSNR: {best_ssim_model_psnr:.4f}, SSIM: {best_ssim_model_ssim:.4f}, nmse: {best_ssim_model_nmse:.4f}')
    print(f'Best nmse model achieved at epoch {epoch_nmse}, PSNR: {best_nmse_model_psnr:.4f}, SSIM: {best_nmse_model_ssim:.4f}, nmse: {best_nmse_model_nmse:.4f}')
    if best_psnr_ema_model is not None:
        print(f'Best EMA PSNR model achieved at epoch {epoch_psnr_ema}, PSNR: {best_psnr_ema_model_psnr:.4f}, SSIM: {best_psnr_ema_model_ssim:.4f}, nmse: {best_psnr_ema_model_nmse:.4f}')
    return best_psnr_model, best_ssim_model, best_nmse_model, best_psnr_model_psnr, best_psnr_model_ssim, best_psnr_model_nmse, best_psnr_model_psnr_std, best_psnr_model_ssim_std, best_psnr_model_nmse_std, best_ssim_model_psnr, best_ssim_model_ssim, best_ssim_model_nmse, best_ssim_model_psnr_std, best_ssim_model_ssim_std, best_ssim_model_nmse_std, best_nmse_model_psnr, best_nmse_model_ssim, best_nmse_model_nmse, best_nmse_model_psnr_std, best_nmse_model_ssim_std, best_nmse_model_nmse_std


def test(model, test_loader, device, use_bf16=False):
    test_model = copy.deepcopy(model)
    psnr_list = []
    ssim_list = []
    nmse_list = []
    test_model = test_model.to(device)
    test_model.eval()
    cases_recon_Result = {}
    cases_hq = {}
    cases_lq = {}
    file_name_list = []
    hq_temp_list = []
    recon_temp_list = []
    # lq_temp_list = []
    with torch.no_grad():
        for i, (imgLQ, imgHQ, sampled) in tqdm(enumerate(test_loader), total=len(test_loader)):
            imgHQ = imgHQ.type(torch.FloatTensor)
            imgLQ = imgLQ.type(torch.FloatTensor)
            imgLQ = imgLQ.to(device)
            imgHQ = imgHQ.to(device)
            mask_we_use = sampled['mask'].to(device)
            lq_kspace = sampled['masked_kspace'].to(device)
            output = _forward_model(test_model, imgLQ, mask_we_use, lq_kspace, use_bf16)
            name = sampled['name']
            name_list= [f.split('_slice_')[0] for f in name]
            mean_current_batch = sampled['mean'].numpy().reshape(-1,1,1,1)
            std_current_batch = sampled['std'].numpy().reshape(-1,1,1,1)
            # de-normalize
            # print(imgHQ.shape, std_current_batch.shape, mean_current_batch.shape)
            imgHQ = imgHQ.cpu().numpy() * std_current_batch + mean_current_batch
            output = output.cpu().numpy() * std_current_batch + mean_current_batch
            # imgLQ = imgLQ.cpu().numpy() * std_current_batch + mean_current_batch
            # print(name_list)
            file_name_list.extend(name_list)
            hq_temp_list.extend(imgHQ.squeeze())
            recon_temp_list.extend(output.squeeze())
            # print(imgHQ.shape, output.shape)
            # lq_temp_list.extend(imgLQ.squeeze())
            # print(len(file_name_list), len(hq_temp_list), len(recon_temp_list))
        for idx,keys in enumerate(file_name_list):
            if keys not in cases_hq:
                cases_hq[keys] = []
                cases_recon_Result[keys] = []
                cases_lq[keys] = []
            cases_hq[keys].append(hq_temp_list[idx])
            cases_recon_Result[keys].append(recon_temp_list[idx])
            # cases_lq[keys].append(lq_temp_list[idx])
        for keys in tqdm(cases_hq.keys(), total=len(cases_hq.keys())):
            hq_vol = np.stack(cases_hq[keys], axis=0)
            recon_vol = np.stack(cases_recon_Result[keys], axis=0)
            # hq_vol = hq_vol * 7.019048643996939e-05 
            # hq_vol = hq_vol + 5.394078107201494e-05
            # recon_vol = recon_vol * 7.019048643996939e-05
            # recon_vol = recon_vol + 5.394078107201494e-05
            # lq_vol = np.stack(cases_lq[keys], axis=0)
            # lq_vol = lq_vol[:,0,:,: ]**2 + lq_vol[:,1,:,:]**2
            # lq_vol = lq_vol.squeeze()
            # lq_vol = np.sqrt(lq_vol)
            # psnr_val = psnr(hq_vol, lq_vol)
            # ssim_val = ssim(hq_vol, lq_vol)
            # nmse_val = nmse(hq_vol, lq_vol)
            # test use lq
            psnr_val = psnr(hq_vol, recon_vol)
            ssim_val = ssim(hq_vol, recon_vol)
            nmse_val = nmse(hq_vol, recon_vol)
            psnr_list.append(psnr_val)
            ssim_list.append(ssim_val)
            nmse_list.append(nmse_val)

    return np.mean(psnr_list), np.mean(ssim_list), np.mean(nmse_list), np.std(psnr_list), np.std(ssim_list), np.std(nmse_list)


